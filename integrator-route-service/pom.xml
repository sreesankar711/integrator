	<artifactId>integrator-route-service</artifactId>

    <name>integrator-route-service</name>
    <description>integrator-route-service</description>

	<dependencies>
        <dependency>
            <groupId>com.integrator</groupId>
            <artifactId>integrator-common</artifactId>
            <version>${project.version}</version>
